{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "Node",
        "declaration": true,
        "esModuleInterop": true,
        "strict": true,
        "resolveJsonModule": true,
        "outDir": "build",
        "rootDir": "src",
        "baseUrl": "src",
        "types": ["node"],
        "paths": {
            "DBManager/*": [ "DBManager/*" ],
            "managers/*": [ "managers/*" ],
            "helper/*": [ "helper/*" ],
            "config/*": [ "config/*" ]
        }
    },
    "include": [ "src/**/*.ts" ]
}